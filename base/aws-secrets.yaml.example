# Example AWS secrets manifest for the data-jobs namespace.
#
# Copy this file to aws-secrets.yaml, fill in real values, then apply with:
#   kubectl apply -f base/aws-secrets.yaml
#
# IMPORTANT: aws-secrets.yaml is excluded from version control via .gitignore.
# Never commit real credentials to this repository.

apiVersion: v1
kind: Secret
metadata:
  name: aws-credentials
  namespace: data-jobs
type: Opaque
stringData:
  AWS_ACCESS_KEY_ID: "your-access-key-id"
  AWS_SECRET_ACCESS_KEY: "your-secret-access-key"
  AWS_DEFAULT_REGION: "us-east-1"
