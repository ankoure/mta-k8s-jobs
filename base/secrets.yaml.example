# Example secrets manifest for the data-jobs namespace.
#
# Copy this file to secrets.yaml, fill in real values, then apply with:
#   kubectl apply -f base/secrets.yaml
#
# IMPORTANT: secrets.yaml is excluded from version control via .gitignore.
# Never commit real credentials to this repository.

apiVersion: v1
kind: Secret
metadata:
  name: r2-credentials
  namespace: data-jobs
type: Opaque
stringData:
  R2_ACCESS_KEY_ID: "your-access-key-id"
  R2_SECRET_ACCESS_KEY: "your-secret-access-key"
  R2_BUCKET_NAME: "your-bucket-name"
  R2_ENDPOINT_URL: "https://<account-id>.r2.cloudflarestorage.com"
